---
// Mise en vedette de la page interactive « Qu'est-ce que la bière ? »
---
<section class="une" id="une">
  <div class="wrap">
    <article class="une-card reveal">
      <div class="une-txt">
        <span class="tag">Page interactive</span>
        <h2>Qu'est-ce que <em>la bi&egrave;re</em>&nbsp;?</h2>
        <p>De l'eau au verre&nbsp;: le proc&eacute;d&eacute; &eacute;tape par &eacute;tape, le r&ocirc;le de chaque ingr&eacute;dient, et la matrice aromatique infinie &agrave; manipuler du bout des doigts.</p>
        <a class="lnk" href="/quest-ce-que-la-biere.html">Explorer l'exp&eacute;rience <span class="arrow">→</span></a>
      </div>
      <div class="une-vis">
        <div class="une-chips" id="uneChips"></div>
        <svg viewBox="0 0 200 320" aria-hidden="true">
          <defs><linearGradient id="robe" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="#F2B53D"/><stop offset="1" stop-color="#C8821A"/></linearGradient></defs>
          <path d="M40,18 L160,18 L150,250 Q148,288 100,288 Q52,288 50,250 Z" fill="rgba(255,255,255,.06)" stroke="rgba(255,255,255,.45)" stroke-width="3"/>
          <path d="M48,66 L152,66 L149.5,250 Q148,282 100,282 Q52,282 50.5,250 Z" fill="url(#robe)" opacity=".95"/>
          <ellipse cx="100" cy="64" rx="52" ry="13" fill="#FDF6E3"/>
          <ellipse cx="78" cy="58" rx="14" ry="7" fill="#fff"/>
          <g id="uneBul"></g>
        </svg>
      </div>
    </article>
  </div>
</section>
<style>
  .une{padding:100px 0 40px}
  .une-card{position:relative;display:grid;grid-template-columns:1.15fr .85fr;border-radius:26px;overflow:hidden;background:linear-gradient(150deg,var(--vert),#143027 60%,var(--vert-d));box-shadow:0 30px 70px rgba(27,58,46,.22)}
  @media(max-width:820px){.une-card{grid-template-columns:1fr}}
  .une-txt{padding:54px 50px;color:#E9F1EC;display:flex;flex-direction:column;justify-content:center}
  .une-txt .tag{align-self:flex-start;background:var(--jaune);color:var(--vert);font-weight:700;font-size:.74rem;letter-spacing:.12em;text-transform:uppercase;padding:6px 14px;border-radius:999px;margin-bottom:20px}
  .une-txt h2{color:#FDFBF6;font-size:clamp(1.8rem,3.6vw,2.7rem);margin-bottom:14px}
  .une-txt h2 em{font-style:italic;color:var(--jaune)}
  .une-txt p{color:#BBD2C6;max-width:46ch;margin-bottom:26px}
  .une-txt .lnk{color:var(--jaune)}
  .une-vis{position:relative;display:flex;align-items:center;justify-content:center;padding:30px;background:radial-gradient(circle at 50% 40%,#2c5749 0%,transparent 70%)}
  .une-vis svg{width:min(180px,40vw);filter:drop-shadow(0 24px 50px rgba(0,0,0,.45))}
  .une-chips{position:absolute;inset:0;pointer-events:none}
  .une-chip{position:absolute;font-size:.74rem;font-weight:600;padding:5px 12px;border-radius:999px;background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.22);color:#fff;backdrop-filter:blur(3px);white-space:nowrap}
</style>
<script>
  const rm = matchMedia('(prefers-reduced-motion: reduce)').matches;
  const cbox = document.getElementById('uneChips');
  if (cbox) {
    ['caramel','agrumes','houblon','épices'].forEach((c,i)=>{
      const s=document.createElement('span');s.className='une-chip';s.textContent=c;
      s.style.left=(12+(i%2)*52)+'%';s.style.top=(16+i*20)+'%';cbox.appendChild(s);
      if(!rm)s.animate([{transform:'translateY(0)'},{transform:'translateY(-9px)'},{transform:'translateY(0)'}],{duration:3200+i*400,iterations:Infinity,easing:'ease-in-out',delay:i*300});
    });
  }
  const ub=document.getElementById('uneBul');
  if(ub && !rm){
    for(let i=0;i<6;i++){const c=document.createElementNS('http://www.w3.org/2000/svg','circle');
      c.setAttribute('r',String(1.6+Math.random()*2.4));c.setAttribute('cx',String(62+Math.random()*76));
      c.setAttribute('cy','262');c.setAttribute('fill','rgba(255,255,255,.5)');ub.appendChild(c);
      c.animate([{transform:'translateY(0)',opacity:0},{opacity:.7,offset:.15},{transform:'translateY(-180px)',opacity:0}],{duration:(2.6+Math.random()*2.2)*1000,iterations:Infinity,delay:Math.random()*2500});
    }
  }
</script>

---
// Hero éditorial de la page d'accueil.
---
<header class="hero">
  <canvas id="bulles" aria-hidden="true"></canvas>
  <div class="wrap">
    <span class="eyebrow hero-eyebrow">Carnet de brassage &amp; zythologie</span>
    <h1>Le savoir-faire derri&egrave;re chaque <em>gorg&eacute;e</em>.</h1>
    <p class="hero-sub">Recettes, styles, techniques et ressources pour brasseurs curieux &mdash; et une plong&eacute;e interactive dans la mati&egrave;re vivante qu'est la bi&egrave;re.</p>
  </div>
</header>

<style>
  .hero{position:relative;min-height:100vh;display:flex;align-items:center;background:radial-gradient(120% 90% at 80% 10%,#23493B 0%,var(--vert) 40%,var(--vert-d) 100%);overflow:hidden}
  #bulles{position:absolute;inset:0;width:100%;height:100%;z-index:1;opacity:.75}
  .hero .wrap{position:relative;z-index:3;padding:120px 28px 80px}
  .hero-eyebrow{color:var(--jaune)}
  .hero-eyebrow::before{background:var(--jaune)}
  .hero h1{color:#FDFBF6;font-size:clamp(2.7rem,7.5vw,5.6rem);font-weight:900;max-width:15ch;margin:24px 0;letter-spacing:-.01em}
  .hero h1 em{font-style:italic;color:var(--jaune)}
  .hero-sub{max-width:540px;color:#CADCD0;font-size:1.18rem}
  .hero-cta{margin-top:38px;display:flex;gap:14px;flex-wrap:wrap}
</style>

<script>
  const rm = matchMedia('(prefers-reduced-motion: reduce)').matches;
  const cv = document.getElementById('bulles') as HTMLCanvasElement | null;
  if (cv && !rm) {
    const cx = cv.getContext('2d')!;
    let W = 0, H = 0;
    const B = Array.from({ length: 46 }, () => ({
      x: Math.random(), y: Math.random(), r: 1 + Math.random() * 3.4,
      v: 0.0005 + Math.random() * 0.0015, o: 0.1 + Math.random() * 0.28, w: Math.random() * 6.3,
    }));
    const rz = () => { W = cv.width = cv.offsetWidth; H = cv.height = cv.offsetHeight; };
    addEventListener('resize', rz); addEventListener('load', rz); rz();
    const loop = (t: number) => {
      cx.clearRect(0, 0, W, H);
      for (const b of B) {
        b.y -= b.v; if (b.y < -0.05) { b.y = 1.05; b.x = Math.random(); }
        const x = b.x * W + Math.sin(t * 0.001 + b.w) * 8;
        cx.beginPath(); cx.arc(x, b.y * H, b.r, 0, 6.3);
        cx.fillStyle = `rgba(245,200,66,${b.o})`; cx.fill();
      }
      requestAnimationFrame(loop);
    };
    requestAnimationFrame(loop);
  }
</script>

---
import Icon from './Icon.astro';
import { useTranslations, getLang } from '../i18n/ui';
const lang = getLang(Astro.currentLocale);
const t = useTranslations(lang);
const jb = lang === 'en' ? '/en/journal/' : '/journal/';
---
<section class="themes" id="themes">
  <div class="wrap">
    <span class="eyebrow reveal" style="margin-bottom:34px;display:inline-block">{t('tiles.eyebrow')}</span>
    <div class="tiles">
      <a class="tile t-recettes reveal" href={jb + '?cat=recettes'}>
        <Icon name="malt" class="t-ico" />
        <div class="tile-content"><h3>{t('nav.recettes')}</h3><p>{t('tiles.recettes')}</p><span class="go">{t('tiles.go')} <span class="arrow">&rarr;</span></span></div>
      </a>
      <a class="tile t-fabrication reveal" href={jb + '?cat=fabrication'}>
        <Icon name="flask" class="t-ico" />
        <div class="tile-content"><h3>{t('nav.fabrication')}</h3><p>{t('tiles.fabrication')}</p><span class="go">{t('tiles.go')} <span class="arrow">&rarr;</span></span></div>
      </a>
      <a class="tile t-styles reveal" href={jb + '?cat=styles'}>
        <Icon name="houblon" class="t-ico" />
        <div class="tile-content"><h3>{t('nav.styles')}</h3><p>{t('tiles.styles')}</p><span class="go">{t('tiles.go')} <span class="arrow">&rarr;</span></span></div>
      </a>
      <a class="tile t-ressources reveal" href={jb + '?cat=ressources'}>
        <Icon name="book" class="t-ico" />
        <div class="tile-content"><h3>{t('nav.ressources')}</h3><p>{t('tiles.ressources')}</p><span class="go">{t('tiles.go')} <span class="arrow">&rarr;</span></span></div>
      </a>
    </div>
  </div>
</section>
<style>
  .themes{padding:30px 0 90px}
  .tiles{display:grid;grid-template-columns:repeat(4,1fr);gap:20px}
  @media(max-width:980px){.tiles{grid-template-columns:repeat(2,1fr)}}
  @media(max-width:560px){.tiles{grid-template-columns:1fr}}
  .tile{position:relative;border-radius:20px;padding:34px 28px;min-height:236px;display:flex;flex-direction:column;justify-content:flex-end;overflow:hidden;color:#fff;transition:transform .4s}
  .tile:hover{transform:translateY(-6px)}
  .tile::after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,transparent 30%,rgba(0,0,0,.32));z-index:1}
  .t-recettes{background:linear-gradient(150deg,#C8821A,#8A5A12)}
  .t-fabrication{background:linear-gradient(150deg,#378ADD,#185FA5)}
  .t-styles{background:linear-gradient(150deg,#5E9A33,#3B6D11)}
  .t-ressources{background:linear-gradient(150deg,#6A5ACD,#473C9E)}
  .tile :global(.t-ico){position:absolute;top:24px;right:24px;z-index:2;width:42px;height:42px;color:rgba(255,255,255,.55);transition:transform .5s,color .4s}
  .tile:hover :global(.t-ico){transform:rotate(8deg) scale(1.1);color:rgba(255,255,255,.85)}
  .tile-content{position:relative;z-index:2}
  .tile h3{color:#fff;font-size:1.55rem;margin-bottom:6px}
  .tile p{color:rgba(255,255,255,.85);font-size:.9rem}
  .tile .go{display:inline-flex;align-items:center;gap:8px;margin-top:14px;font-weight:700;font-size:.9rem;color:#fff}
</style>

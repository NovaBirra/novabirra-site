---
import Icon from './Icon.astro';
interface Props { href: string; category: string; accent: string; title: string; dek: string; meta: string; }
const { href, category, accent, title, dek, meta } = Astro.props;
const icon = accent === 'fabrication' ? 'flask' : accent === 'styles' ? 'houblon' : accent === 'ressources' ? 'book' : (Math.random() > .5 ? 'houblon' : 'malt');
---
<article class="card reveal">
  <a href={href} class="card-vis" data-accent={accent} aria-hidden="true">
    <span class="cat">{category}</span>
    <Icon name={icon as any} />
  </a>
  <div class="card-body">
    <h3><a href={href}>{title}</a></h3>
    <p>{dek}</p>
    <span class="card-date">{meta}</span>
  </div>
</article>
<style>
  .card{display:flex;flex-direction:column;border-radius:18px;overflow:hidden;background:#fff;border:1px solid var(--ligne);transition:transform .35s cubic-bezier(.2,.8,.3,1),box-shadow .35s}
  .card:hover{transform:translateY(-7px);box-shadow:0 24px 50px rgba(27,58,46,.13)}
  .card-vis{height:172px;position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center}
  .card-vis :global(svg){width:62px;height:62px;color:#fff;transition:transform .5s}
  .card:hover .card-vis :global(svg){transform:scale(1.12) rotate(-6deg)}
  .card-vis[data-accent="recettes"]{background:linear-gradient(135deg,#E7A23B,#BA7517)}
  .card-vis[data-accent="fabrication"]{background:linear-gradient(135deg,#5BA6E8,#2E6FB0)}
  .card-vis[data-accent="styles"]{background:linear-gradient(135deg,#7FBF45,#4E8A26)}
  .card-vis[data-accent="ressources"]{background:linear-gradient(135deg,#8579E0,#473C9E)}
  .cat{position:absolute;top:14px;left:14px;background:rgba(255,255,255,.92);color:var(--vert);font-weight:700;font-size:.7rem;letter-spacing:.08em;text-transform:uppercase;padding:5px 12px;border-radius:999px}
  .card-body{padding:22px 22px 26px;flex:1;display:flex;flex-direction:column}
  .card-body h3{font-size:1.28rem;margin-bottom:8px;transition:color .25s}
  .card:hover .card-body h3{color:var(--houblon-d)}
  .card-body p{color:#55544E;font-size:.93rem;flex:1}
  .card-date{margin-top:16px;font-size:.78rem;color:var(--gris);font-weight:600;letter-spacing:.03em}
</style>

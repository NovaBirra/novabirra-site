---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  navVariant?: 'hero' | 'solid';
  progress?: boolean;          // barre de progression de lecture (articles)
}
const {
  title,
  description = "Recettes, styles, techniques et ressources pour brasseurs curieux. Le carnet de brassage de NovaBirra.",
  navVariant = 'solid',
  progress = false,
} = Astro.props;
---
<!DOCTYPE html>
<html lang={Astro.currentLocale ?? 'fr'}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,500;0,700;0,900;1,400;1,500&family=Source+Sans+3:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body>
  {progress && <div id="progress"></div>}
  <Nav variant={navVariant} />
  <main>
    <slot />
  </main>
  <Footer />

  <style is:global>
    #progress{position:fixed;top:0;left:0;height:3px;width:0;background:var(--jaune);z-index:60;transition:width .1s linear}
  </style>

  <script>
    // Révélation au scroll (partagé)
    const io = new IntersectionObserver(
      (es) => es.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } }),
      { threshold: 0.14 }
    );
    document.querySelectorAll('.reveal').forEach((el) => io.observe(el));

    // Nav : opacifie au défilement (uniquement en variante "hero")
    const nav = document.getElementById('nav');
    if (nav && nav.dataset.variant === 'hero') {
      const onScroll = () => nav.classList.toggle('solid', window.scrollY > 60);
      addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    }

    // Barre de progression de lecture
    const pb = document.getElementById('progress');
    if (pb) {
      addEventListener('scroll', () => {
        const h = document.documentElement.scrollHeight - innerHeight;
        pb.style.width = (h > 0 ? (scrollY / h) * 100 : 0) + '%';
      }, { passive: true });
    }
  </script>
</body>
</html>

  plats.frais.style.transformOrigin='170px 0px';
  plats.rond.style.transform=`translate(-170px,0) rotate(${-angle}deg)`;
  plats.frais.style.transform=`translate(170px,0) rotate(${-angle}deg)`;
  const pos=280+(b-a)*34;
  spectreCur.style.transition=tr;
  spectreCur.style.transform=`translate(${Math.max(96,Math.min(464,pos))}px,292px)`;
  verdict.innerHTML='&laquo;&nbsp;'+s.v+'&nbsp;&raquo;';
}
const listeEl=document.getElementById('styles-liste');
STYLES.forEach((s,i)=>{
  const b=document.createElement('button');
  b.className='style-btn';b.setAttribute('role','option');b.setAttribute('aria-selected',i===0);
  b.innerHTML=`<span>${s.n}</span><span class="abv">${s.abv}</span>`;
  b.addEventListener('click',()=>{
    [...listeEl.children].forEach((x,j)=>x.setAttribute('aria-selected',j===i));
    montreStyle(s);
  });
  listeEl.appendChild(b);
});
montreStyle(STYLES[0]);

/* ============ matrice aromatique ============ */
const EBC=[['#F8E9A0','#E8C75A'],['#F2B53D','#C8821A'],['#D98E2B','#9C5E14'],['#A85B1B','#6E3A0E'],['#6E3517','#3F1E0B'],['#3A1D0E','#17100B']];
const AROMES={
 malt:[[10,'pain frais'],[30,'biscuit'],[50,'caramel'],[72,'chocolat'],[90,'caf&eacute; torr&eacute;fi&eacute;']],
 houblon:[[15,'herbes'],[35,'fleurs'],[55,'agrumes'],[75,'r&eacute;sine de pin'],[92,'fruits exotiques']],
 levure:[[25,'poire'],[45,'banane'],[65,'&eacute;pices \u00B7 clou de girofle'],[85,'acidit&eacute; vive']],
 corps:[[20,'sec'],[55,'soyeux'],[85,'liquoreux']]
};
const sliders={malt:document.getElementById('m-malt'),houblon:document.getElementById('m-houblon'),levure:document.getElementById('m-levure'),corps:document.getElementById('m-corps')};
const labels={malt:document.getElementById('v-malt'),houblon:document.getElementById('v-houblon'),levure:document.getElementById('v-levure'),corps:document.getElementById('v-corps')};
const MOTS={
 malt:['p&acirc;le','dor&eacute;','ambr&eacute;','cuivr&eacute;','brun','noir'],
 houblon:['discret','pr&eacute;sent','g&eacute;n&eacute;reux','intense','explosif'],
 levure:['neutres','sages','expressives','exub&eacute;rantes'],
 corps:['sec','l&eacute;ger','moyen','rond','liquoreux']
};
function lerp(c1,c2,t){
  const p=h=>[parseInt(h.slice(1,3),16),parseInt(h.slice(3,5),16),parseInt(h.slice(5,7),16)];
  const a=p(c1),b=p(c2);
  return '#'+a.map((v,i)=>Math.round(v+(b[i]-v)*t).toString(16).padStart(2,'0')).join('');
}
const aromesBox=document.getElementById('aromes');
let aTimer;
function majMatrice(){
  const m=+sliders.malt.value,h=+sliders.houblon.value,l=+sliders.levure.value,c=+sliders.corps.value;
  labels.malt.innerHTML=MOTS.malt[Math.min(5,Math.floor(m/17))];
  labels.houblon.innerHTML=MOTS.houblon[Math.min(4,Math.floor(h/21))];
  labels.levure.innerHTML=MOTS.levure[Math.min(3,Math.floor(l/26))];
  labels.corps.innerHTML=MOTS.corps[Math.min(4,Math.floor(c/21))];
  /* robe */
  const f=m/100*(EBC.length-1),i=Math.min(EBC.length-2,Math.floor(f)),t=f-i;
  document.getElementById('rs1').setAttribute('stop-color',lerp(EBC[i][0],EBC[i+1][0],t));
  document.getElementById('rs2').setAttribute('stop-color',lerp(EBC[i][1],EBC[i+1][1],t));
  /* mousse : plus de corps = mousse plus cr&eacute;meuse */
  document.getElementById('mousse').setAttribute('ry',10+c/100*7);
  /* nuage d'ar&ocirc;mes */
  clearTimeout(aTimer);
  aTimer=setTimeout(()=>{
    const actifs=[];
    for(const[k,seuils]of Object.entries(AROMES)){
      const v=+sliders[k].value;
      let best=null;for(const[s,mot]of seuils)if(v>=s)best=mot;
      if(best&&k!=='corps')actifs.push(best);
    }
    aromesBox.innerHTML='';
    actifs.slice(0,4).forEach((mot,idx)=>{
      const tag=document.createElement('span');
      tag.className='arome';tag.innerHTML=mot;
      tag.style.left = window.innerWidth>900 ? '4%' : '8px';
      tag.style.right='auto';
      tag.style.top=`calc(22% + ${idx*44}px)`;
      aromesBox.appendChild(tag);
      setTimeout(()=>tag.classList.add('on'),60+idx*110);
    });
    majStyle(m,h,l,c);
  },140);
}
function majStyle(m,h,l,c){
  let nom,desc;
  if(h>72&&m<40){nom='IPA aromatique';desc='Houblon en avant, robe claire, finale s&egrave;che et parfum&eacute;e.'}
  else if(m>78&&c>60){nom='Stout imp&eacute;rial';desc='Caf&eacute; et chocolat, corps liquoreux, puissance enveloppante.'}
  else if(m>78){nom='Porter / Stout';desc='Torr&eacute;faction franche, corps ma&icirc;tris&eacute;, amertume de caf&eacute;.'}
  else if(l>78&&m<35){nom='Bi&egrave;re acide / Berliner';desc='Acidit&eacute; vive, robe p&acirc;le, fra&icirc;cheur d&eacute;salt&eacute;rante.'}
  else if(l>62&&m>45){nom='Dubbel d\u2019abbaye';desc='Fruits m&ucirc;rs et &eacute;pices de fermentation sur fond caramel.'}
  else if(l>62){nom='Saison fermi&egrave;re';desc='Levures expressives, poivre et fruits, finale s&egrave;che.'}
  else if(m<28&&h<38&&c<45){nom='Pils / Lager';desc='Pure, nette, d&eacute;salt&eacute;rante - la pr&eacute;cision avant tout.'}
  else if(c>72){nom='Quadrupel';desc='Moelleux profond, fruits confits, chaleur g&eacute;n&eacute;reuse.'}
  else if(m>=40&&m<=70&&h>=38&&h<=65){nom='Ambr&eacute;e &eacute;quilibr&eacute;e';desc='Caramel doux, houblon pr&eacute;sent sans dominer - l\u2019&eacute;quilibre.'}
  else{nom='Cr&eacute;ation libre';desc='Hors des sentiers battus - c\u2019est l&agrave; que na&icirc;t la nouveaut&eacute;.'}
  document.getElementById('mat-style').innerHTML=nom;
  document.getElementById('mat-desc').innerHTML=desc;
}
Object.values(sliders).forEach(s=>s.addEventListener('input',majMatrice));
majMatrice();

/* bulles dans le verre de la matrice */
const vb=document.getElementById('vbulles');
if(!rm){
  for(let i=0;i<7;i++){
    const c=document.createElementNS('http://www.w3.org/2000/svg','circle');
    c.setAttribute('r',1.6+Math.random()*2.6);
    c.setAttribute('cx',62+Math.random()*76);
    c.setAttribute('fill','rgba(255,255,255,.5)');
    vb.appendChild(c);
    const dur=2.6+Math.random()*2.4;
    c.animate([{transform:'translateY(0px)',opacity:0},{opacity:.7,offset:.15},{transform:'translateY(-185px)',opacity:0}],{duration:dur*1000,iterations:Infinity,delay:Math.random()*2600});
    c.setAttribute('cy',262);
  }
}

/* compteur anim&eacute; */
const cible=100000000,el=document.getElementById('compteur');
const ioC=new IntersectionObserver(es=>{
  if(es[0].isIntersecting){
    ioC.disconnect();
    if(rm){el.textContent='100\u00A0000\u00A0000';return}
    const t0=performance.now(),dur=2200;
    function tick(t){
      const p=Math.min(1,(t-t0)/dur),e=1-Math.pow(1-p,3);
      el.textContent=Math.round(cible*e).toLocaleString('fr-BE');
      if(p<1)requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }
},{threshold:.4});
ioC.observe(el);

</script>

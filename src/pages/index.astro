---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import FeatureInteractive from '../components/FeatureInteractive.astro';
import ThemeTiles from '../components/ThemeTiles.astro';
import AproposBand from '../components/AproposBand.astro';
import Newsletter from '../components/Newsletter.astro';
import JournalCard from '../components/JournalCard.astro';
import { getCollection } from 'astro:content';

// Les 3 derniers articles, du plus récent au plus ancien.
const posts = (await getCollection('journal', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const fmtDate = (d: Date) =>
  d.toLocaleDateString('fr-BE', { month: 'long', year: 'numeric' });
const catLabel = (c: string) => (c === 'Recette' ? 'Recette' : c === 'Fabrication' ? 'Technique' : c);
---
<Base title="NovaBirra — Carnet de brassage & zythologie" navVariant="hero">
  <Hero />
  <FeatureInteractive />

  <!-- LE JOURNAL -->
  <section class="journal" id="journal">
    <div class="wrap">
      <div class="sec-head reveal">
        <div><span class="eyebrow">Le journal</span><h2>Derniers articles</h2></div>
        <a class="lnk" href="/journal/" style="color:var(--houblon-d)">Tous les articles <span class="arrow">→</span></a>
      </div>
      <div class="cards">
        {posts.map((p) => (
          <JournalCard
            href={`/journal/${p.slug}/`}
            category={p.data.category}
            accent={p.data.accent}
            title={p.data.title}
            dek={p.data.dek}
            meta={`${catLabel(p.data.category)} · ${fmtDate(p.data.date)}`}
          />
        ))}
      </div>
    </div>
  </section>

  <ThemeTiles />
  <AproposBand />
  <Newsletter />
</Base>

<style>
  .journal{padding:90px 0}
  .sec-head{display:flex;align-items:flex-end;justify-content:space-between;gap:20px;margin-bottom:42px;flex-wrap:wrap}
  .sec-head h2{font-size:clamp(1.9rem,4vw,2.9rem);margin-top:10px}
  .cards{display:grid;grid-template-columns:repeat(3,1fr);gap:26px}
  @media(max-width:900px){.cards{grid-template-columns:repeat(2,1fr)}}
  @media(max-width:600px){.cards{grid-template-columns:1fr}}
</style>

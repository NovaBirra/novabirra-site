---
import Base from '../../layouts/Base.astro';
import JournalCard from '../../components/JournalCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('journal', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const fmtDate = (d: Date) => d.toLocaleDateString('fr-BE', { month: 'long', year: 'numeric' });
const catLabel = (c: string) => (c === 'Recette' ? 'Recette' : c === 'Fabrication' ? 'Technique' : c);
---
<Base title="Le journal | NovaBirra" description="Tous les articles, recettes et techniques du carnet NovaBirra.">
  <header class="list-hero">
    <div class="wrap">
      <span class="eyebrow">Le journal</span>
      <h1>Le carnet de brassage</h1>
      <p>Recettes, techniques, lectures de styles et ressources&nbsp;: tout ce qu'on a appris &agrave; partager.</p>
    </div>
  </header>

  <section class="list">
    <div class="wrap">
      <div class="filters" role="tablist" aria-label="Filtrer par cat&eacute;gorie">
        <button class="filter is-active" data-filter="all">Tout</button>
        <button class="filter" data-filter="recettes">Recettes</button>
        <button class="filter" data-filter="fabrication">Fabrication</button>
        <button class="filter" data-filter="styles">Styles</button>
        <button class="filter" data-filter="ressources">Ressources</button>
      </div>
      <div class="cards">
        {posts.map((p) => (
          <JournalCard
            href={`/journal/${p.slug}/`}
            category={p.data.category}
            accent={p.data.accent}
            title={p.data.title}
            dek={p.data.dek}
            meta={`${catLabel(p.data.category)} · ${fmtDate(p.data.date)}`}
          />
        ))}
      </div>
      <p class="no-results" hidden>Aucun article dans cette cat&eacute;gorie pour le moment.</p>
    </div>
  </section>
</Base>

<style>
  .list-hero{background:radial-gradient(120% 100% at 75% 0%,#23493B,var(--vert) 45%,var(--vert-d));color:#E9F1EC;padding:140px 0 70px}
  .list-hero .eyebrow{color:var(--jaune)}.list-hero .eyebrow::before{background:var(--jaune)}
  .list-hero h1{color:#FDFBF6;font-size:clamp(2.4rem,6vw,4rem);font-weight:900;margin:16px 0 14px}
  .list-hero p{color:#C6D8CD;font-size:1.18rem;max-width:56ch}
  .list{padding:70px 0 90px}
  .cards{display:grid;grid-template-columns:repeat(3,1fr);gap:26px}
  @media(max-width:900px){.cards{grid-template-columns:repeat(2,1fr)}}
  @media(max-width:600px){.cards{grid-template-columns:1fr}}
  .filters{display:flex;flex-wrap:wrap;gap:10px;margin-bottom:36px}
  .filter{font-family:inherit;font-size:.9rem;font-weight:600;letter-spacing:.02em;color:var(--vert);background:#fff;border:1px solid var(--ligne);padding:9px 20px;border-radius:999px;cursor:pointer;transition:background .2s,color .2s,border-color .2s,transform .15s}
  .filter:hover{border-color:var(--vert);background:#F3EFE6}
  .filter:active{transform:scale(.96)}
  .filter.is-active{color:#fff;border-color:var(--vert);background:var(--vert)}
  .filter[data-filter="recettes"].is-active{background:#BA7517;border-color:#BA7517}
  .filter[data-filter="fabrication"].is-active{background:#2E6FB0;border-color:#2E6FB0}
  .filter[data-filter="styles"].is-active{background:#4E8A26;border-color:#4E8A26}
  .filter[data-filter="ressources"].is-active{background:#473C9E;border-color:#473C9E}
  :global(.card.hide){display:none}
  .no-results{text-align:center;color:var(--gris);font-size:1.05rem;padding:30px 0}
</style>

<script>
  const filterBtns = Array.from(document.querySelectorAll('.filter'));
  const cards = Array.from(document.querySelectorAll('.cards .card'));
  const empty = document.querySelector('.no-results');
  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const f = btn.dataset.filter;
      filterBtns.forEach((b) => b.classList.toggle('is-active', b === btn));
      let visible = 0;
      cards.forEach((card) => {
        const match = f === 'all' || card.dataset.accent === f;
        card.classList.toggle('hide', !match);
        if (match) { card.classList.add('in'); visible++; }
      });
      if (empty) empty.hidden = visible !== 0;
    });
  });

  // Filtre initial depuis l'URL (?cat=...) — utilisé par les tuiles « Explorer par thème »
  const initial = new URLSearchParams(location.search).get('cat');
  if (initial) {
    const target = filterBtns.find((b) => b.dataset.filter === initial);
    if (target) target.click();
  }
</script>

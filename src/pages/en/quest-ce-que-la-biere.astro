 filtre:'<svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="30" height="30"><path d="M4 4h16l-6 8v6l-4 2v-8L4 4z"/></svg>',

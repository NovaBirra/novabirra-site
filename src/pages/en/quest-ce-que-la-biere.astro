 flamme:'<svg viewBox="0 0 24 24" fill="#fff" width="30" height="30"><path d="M12 2c1 4-3 5.5-3 9a3.5 3.5 0 0 0 1.6 3C10.2 11.6 14 11 13 7c3 2 6 5 6 9a7 7 0 0 1-14 0c0-5 5-7.5 7-14z"/></svg>',
 flocon:'<svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="1.7" stroke-linecap="round" width="30" height="30"><path d="M12 2v20M3.3 7l17.4 10M3.3 17 20.7 7M12 5l-2.2-2.2M12 5l2.2-2.2M12 19l-2.2 2.2M12 19l2.2 2.2M5.5 8.2 2.5 7.4M5.5 8.2l-.8-3M18.5 15.8l3 .8M18.5 15.8l.8 3M5.5 15.8l-3 .8M5.5 15.8l-.8 3M18.5 8.2l3-.8M18.5 8.2l.8-3"/></svg>',
 fiole:'<svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="30" height="30"><path d="M9 2.5h6M10 2.5V8l-4.6 7.9A3.6 3.6 0 0 0 8.5 21h7a3.6 3.6 0 0 0 3.1-5.1L14 8V2.5"/><path d="M7.3 14.5h9.4" stroke-width="1.5"/><circle cx="11" cy="17.5" r=".9" fill="#fff" stroke="none"/><circle cx="14" cy="16.2" r=".7" fill="#fff" stroke="none"/><circle cx="12.5" cy="11.5" r=".6" fill="#fff" stroke="none"/></svg>',
 verre:'<svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="30" height="30"><path d="M7 3h10l-1 16.2a2 2 0 0 1-2 1.8h-4a2 2 0 0 1-2-1.8L7 3z"/><path d="M7.4 8h9.2" stroke-width="1.5"/><ellipse cx="12" cy="5.5" rx="3.6" ry="1.1" fill="#fff" stroke="none"/></svg>'
};
const ETAPES=[
 {n:"Mashing",d:"",ico:ICO.cuve,t:"It all starts with the mash",
  x:"Hot water meets the crushed malted cereals. The water acts as a solvent: it draws out sugars, proteins, colours and aromas from the grain.",temp:"The brewer chooses the malts &mdash; and already the colour of the future beer"},
 {n:"Saccharification",d:"",ico:ICO.thermo,t:"Saccharification \u2014 65 \u00B0C",
  x:"The amylase enzymes in the malted cereals break the starch into various sugars. The small sugars feed the yeast; the large sugars (dextrins) stay in the beer to give it body.",temp:"60 min at 65 \u00B0C"},
 {n:"Lautering",d:"",ico:ICO.filtre,t:"Lautering the wort",
  x:"We separate the sweet liquid &mdash; the wort &mdash; from the grain husks. These are called spent grains and will go to feed livestock: nothing is wasted.",temp:"The wort: sweet, and soon bitter"},
 {n:"Boil",d:"",ico:ICO.flamme,t:"Boil \u2014 100 \u00B0C",
  x:"The wort boils with the hop flowers. The bitter resins isomerise (bitterness), the essential oils perfume it. Hops are also bacteriostatic: they protect the beer.",temp:"60 min at 100 \u00B0C"},
 {n:"Cooling",d:"",ico:ICO.flocon,t:"Rapid cooling",
  x:"We drop the temperature to welcome the yeast without killing it \u2014 and without giving free rein to the undesirable micro-organisms in the air around us.",temp:"From 100 \u00B0C down to fermentation temperature"},
 {n:"Fermentation",d:"",ico:ICO.fiole,t:"Fermentation",
  x:"The yeast turns the sugars into alcohol and CO\u2082, releases fruity and spicy aromas, and brings the pH down to 4\u20134.5. The fermentation temperature depends on the yeast strain: some prefer to work cold, around 10 \u00B0C, while others are happy fermenting a wort at 40 \u00B0C.",temp:"3 to 12 days depending on the yeast the brewer chooses"},
 {n:"Beer",d:"",ico:ICO.verre,t:"The beer is born",
  x:"Cold conditioning, bottling, bottle conditioning\u2026 then comes the moment of tasting. Every choice the brewer made along the way has sculpted the beer you\u2019re about to taste.",temp:"A beer whose flavour keeps evolving"}
];
const chaine=document.getElementById('chaine');
ETAPES.forEach((e,i)=>{
  const b=document.createElement('button');
  b.className='etape';b.setAttribute('role','tab');b.setAttribute('aria-selected',i===0);
  b.innerHTML=`<span class="pt"></span><span class="nom">${e.n}</span><span class="duree">${e.d}</span>`;
  b.addEventListener('click',()=>selEtape(i));
  chaine.appendChild(b);
});
function selEtape(i){
  [...chaine.children].forEach((b,j)=>{b.setAttribute('aria-selected',j===i);b.classList.toggle('done',j<i)});
  const e=ETAPES[i],ti=document.getElementById('p-titre'),tx=document.getElementById('p-texte');
  ti.style.opacity=0;tx.style.opacity=0;
  setTimeout(()=>{
    document.getElementById('p-ico').innerHTML=e.ico;
    ti.innerHTML=e.t;tx.innerHTML=e.x;
    document.getElementById('p-temp').innerHTML=e.temp;
    ti.style.opacity=1;tx.style.opacity=1;
  },180);
}
selEtape(0);

/* ============ cartes ingr&eacute;dients ============ */
document.querySelectorAll('.carte').forEach(c=>{
  const tog=()=>c.setAttribute('aria-expanded',c.getAttribute('aria-expanded')!=='true');
  c.addEventListener('click',tog);
  c.addEventListener('keydown',e=>{if(e.key==='Enter'||e.key===' '){e.preventDefault();tog()}});
});

/* ============ balance par styles ============ */
const fleau=document.getElementById('bal-fleau'),verdict=document.getElementById('bal-verdict');
const piles={rond:document.getElementById('pile-rond'),frais:document.getElementById('pile-frais')};
const plats={rond:document.getElementById('plat-rond'),frais:document.getElementById('plat-frais')};
const spectreCur=document.getElementById('spectre-curseur');
const NS='http://www.w3.org/2000/svg';
const COULEURS={'Alcohol':'#BA7517','Residual sugars':'#D89A3B','Bitterness':'#639922','Acidity':'#3F9C8F'};
/* alc & suc = roundness (0\u20133) ; amer OR acid = freshness (0\u20133), never both */
const STYLES=[
 {n:'Pils',abv:'~5\u00A0%',alc:1,suc:0,amer:1,acid:0,v:'Light on both sides \u2014 freshness wins by a breath: thirst-quenching.'},
 {n:'Witbier',abv:'4\u20135\u00A0%',alc:1,suc:1,amer:0,acid:1,v:'Cereal roundness with a hint of acidity: the balance of summer.'},
 {n:'Saison',abv:'5\u20136.5\u00A0%',alc:1,suc:0,amer:2,acid:0,v:'Dry and hoppy \u2014 freshness clearly dominates.'},
 {n:'IPA',abv:'6\u20137\u00A0%',alc:2,suc:1,amer:3,acid:0,v:'Generous bitterness carried by a solid body: tension, embraced.'},
 {n:'Berliner Weisse',abv:'~3.5\u00A0%',alc:1,suc:0,amer:0,acid:2,v:'Sharp acidity over a minimal body \u2014 maximum freshness.'},
 {n:'Gueuze',abv:'5\u20137\u00A0%',alc:1,suc:0,amer:0,acid:3,v:'Acidity at its peak, carried by years of spontaneous fermentation.'},
 {n:'Dubbel',abv:'6.5\u20137.5\u00A0%',alc:2,suc:2,amer:1,acid:0,v:'Caramel and ripe fruit: roundness takes the wheel.'},
 {n:'Tripel',abv:'8\u20139.5\u00A0%',alc:3,suc:1,amer:2,acid:0,v:'Powerful but reined in by bitterness \u2014 the great Belgian balance.'},
 {n:'Quadrupel',abv:'10\u201312\u00A0%',alc:3,suc:3,amer:1,acid:0,v:'Maximum roundness \u2014 candied fruit and warmth, bitterness as a mere safeguard.'},
 {n:'Imperial stout',abv:'9\u201312\u00A0%',alc:3,suc:3,amer:2,acid:0,v:'Massive and roasty \u2014 coffee bitterness just holds the sweetness in check.'}
];
function pileSVG(items,side){
  /* items: [{nom,poids}] - un jeton par unit&eacute; de poids, empil&eacute;s */
  piles[side].innerHTML='';
  let idx=0;
  items.forEach(({nom,poids})=>{
    for(let k=0;k<poids;k++){
      const g=document.createElementNS(NS,'g');
      const label=k===0?nom:'';
      const w=Math.max(46,(label.replace(/&[^;]+;/g,'x').length*7.2)+22);
      const y=52-idx*15;
      const r=document.createElementNS(NS,'rect');
      r.setAttribute('x',-w/2);r.setAttribute('y',y);r.setAttribute('width',w);r.setAttribute('height',12.5);
      r.setAttribute('rx',6.2);r.setAttribute('fill',COULEURS[nom]);
      if(k>0)r.setAttribute('opacity',.82);
      g.appendChild(r);
      if(label){
        const t=document.createElementNS(NS,'text');
        t.setAttribute('x',0);t.setAttribute('y',y+9.8);t.setAttribute('text-anchor','middle');
        t.setAttribute('font-size','9.5');t.setAttribute('font-weight','700');t.setAttribute('fill','#fff');
        t.innerHTML=nom;g.appendChild(t);
      }
      if(!rm)g.animate([{transform:'translateY(-100px)',opacity:0},{transform:'translateY(6px)',opacity:1,offset:.7},{transform:'translateY(0)',opacity:1}],{duration:420,delay:idx*70,easing:'cubic-bezier(.3,1.2,.5,1)',fill:'backwards'});
      piles[side].appendChild(g);idx++;
    }
  });
}
function montreStyle(s){
  const rondItems=[],fraisItems=[];
  if(s.alc)rondItems.push({nom:'Alcohol',poids:s.alc});
  if(s.suc)rondItems.push({nom:'Residual sugars',poids:s.suc});
  if(s.amer)fraisItems.push({nom:'Bitterness',poids:s.amer});
  if(s.acid)fraisItems.push({nom:'Acidity',poids:s.acid});
  pileSVG(rondItems,'rond');pileSVG(fraisItems,'frais');
  const a=s.alc+s.suc,b=s.amer+s.acid;
  const angle=Math.max(-13,Math.min(13,(b-a)*3.1));
  const tr=rm?'none':'transform .9s cubic-bezier(.25,1.7,.45,.9)';
  fleau.style.transition=tr;fleau.style.transform=`rotate(${angle}deg)`;
  plats.rond.style.transition=plats.frais.style.transition=tr;
  plats.rond.style.transformOrigin='-170px 0px';
  plats.frais.style.transformOrigin='170px 0px';
  plats.rond.style.transform=`translate(-170px,0) rotate(${-angle}deg)`;
  plats.frais.style.transform=`translate(170px,0) rotate(${-angle}deg)`;
  const pos=280+(b-a)*34;
  spectreCur.style.transition=tr;
  spectreCur.style.transform=`translate(${Math.max(96,Math.min(464,pos))}px,292px)`;
  verdict.innerHTML='&ldquo;'+s.v+'&rdquo;';
}
const listeEl=document.getElementById('styles-liste');
STYLES.forEach((s,i)=>{
  const b=document.createElement('button');
  b.className='style-btn';b.setAttribute('role','option');b.setAttribute('aria-selected',i===0);
  b.innerHTML=`<span>${s.n}</span><span class="abv">${s.abv}</span>`;
  b.addEventListener('click',()=>{
    [...listeEl.children].forEach((x,j)=>x.setAttribute('aria-selected',j===i));
    montreStyle(s);
  });
  listeEl.appendChild(b);
});
montreStyle(STYLES[0]);

/* ============ aromatic matrix ============ */
const EBC=[['#F8E9A0','#E8C75A'],['#F2B53D','#C8821A'],['#D98E2B','#9C5E14'],['#A85B1B','#6E3A0E'],['#6E3517','#3F1E0B'],['#3A1D0E','#17100B']];
const AROMES={
 malt:[[10,'fresh bread'],[30,'biscuit'],[50,'caramel'],[72,'chocolate'],[90,'roasted coffee']],
 houblon:[[15,'herbal'],[35,'flowery'],[55,'citrusy'],[75,'pine resin'],[92,'tropical fruit']],
 levure:[[25,'pear'],[45,'banana'],[65,'spices \u00B7 clove'],[85,'sharp acidity']],
 corps:[[20,'dry'],[55,'silky'],[85,'luscious']]
};
const sliders={malt:document.getElementById('m-malt'),houblon:document.getElementById('m-houblon'),levure:document.getElementById('m-levure'),corps:document.getElementById('m-corps')};
const labels={malt:document.getElementById('v-malt'),houblon:document.getElementById('v-houblon'),levure:document.getElementById('v-levure'),corps:document.getElementById('v-corps')};
const MOTS={
 malt:['pale','gold','amber','copper','brown','black'],
 houblon:['discreet','present','generous','intense','explosive'],
 levure:['neutral','restrained','expressive','exuberant'],
 corps:['dry','light','medium','round','luscious']
};
function lerp(c1,c2,t){
  const p=h=>[parseInt(h.slice(1,3),16),parseInt(h.slice(3,5),16),parseInt(h.slice(5,7),16)];
  const a=p(c1),b=p(c2);
  return '#'+a.map((v,i)=>Math.round(v+(b[i]-v)*t).toString(16).padStart(2,'0')).join('');
}
const aromesBox=document.getElementById('aromes');
let aTimer;
function majMatrice(){
  const m=+sliders.malt.value,h=+sliders.houblon.value,l=+sliders.levure.value,c=+sliders.corps.value;
  labels.malt.innerHTML=MOTS.malt[Math.min(5,Math.floor(m/17))];
  labels.houblon.innerHTML=MOTS.houblon[Math.min(4,Math.floor(h/21))];
  labels.levure.innerHTML=MOTS.levure[Math.min(3,Math.floor(l/26))];
  labels.corps.innerHTML=MOTS.corps[Math.min(4,Math.floor(c/21))];
  /* robe */
  const f=m/100*(EBC.length-1),i=Math.min(EBC.length-2,Math.floor(f)),t=f-i;
  document.getElementById('rs1').setAttribute('stop-color',lerp(EBC[i][0],EBC[i+1][0],t));
  document.getElementById('rs2').setAttribute('stop-color',lerp(EBC[i][1],EBC[i+1][1],t));
  /* mousse : plus de corps = mousse plus cr&eacute;meuse */
  document.getElementById('mousse').setAttribute('ry',10+c/100*7);
  /* nuage d'ar&ocirc;mes */
  clearTimeout(aTimer);
  aTimer=setTimeout(()=>{
    const actifs=[];
    for(const[k,seuils]of Object.entries(AROMES)){
      const v=+sliders[k].value;
      let best=null;for(const[s,mot]of seuils)if(v>=s)best=mot;
      if(best&&k!=='corps')actifs.push(best);
    }
    aromesBox.innerHTML='';
    actifs.slice(0,4).forEach((mot,idx)=>{
      const tag=document.createElement('span');
      tag.className='arome';tag.innerHTML=mot;
      tag.style.left = window.innerWidth>900 ? '4%' : '8px';
      tag.style.right='auto';
      tag.style.top=`calc(22% + ${idx*44}px)`;
      aromesBox.appendChild(tag);
      setTimeout(()=>tag.classList.add('on'),60+idx*110);
    });
    majStyle(m,h,l,c);
  },140);
}
function majStyle(m,h,l,c){
  let nom,desc;
  if(h>72&&m<40){nom='Aromatic IPA';desc='Hops up front, pale colour, a dry and fragrant finish.'}
  else if(m>78&&c>60){nom='Imperial stout';desc='Coffee and chocolate, a luscious body, enveloping power.'}
  else if(m>78){nom='Porter / Stout';desc='Clear roastiness, a controlled body, coffee bitterness.'}
  else if(l>78&&m<35){nom='Sour beer / Berliner';desc='Sharp acidity, pale colour, thirst-quenching freshness.'}
  else if(l>62&&m>45){nom='Abbey Dubbel';desc='Ripe fruit and fermentation spices over a caramel base.'}
  else if(l>62){nom='Farmhouse saison';desc='Expressive yeast, pepper and fruit, a dry finish.'}
  else if(m<28&&h<38&&c<45){nom='Pils / Lager';desc='Pure, clean, thirst-quenching \u2014 precision above all.'}
  else if(c>72){nom='Quadrupel';desc='Deep mellowness, candied fruit, generous warmth.'}
  else if(m>=40&&m<=70&&h>=38&&h<=65){nom='Balanced amber';desc='Soft caramel, hops present without dominating \u2014 balance.'}
  else{nom='Free creation';desc='Off the beaten track \u2014 that\u2019s where novelty is born.'}
  document.getElementById('mat-style').innerHTML=nom;
  document.getElementById('mat-desc').innerHTML=desc;
}
Object.values(sliders).forEach(s=>s.addEventListener('input',majMatrice));
majMatrice();

/* bulles dans le verre de la matrice */
const vb=document.getElementById('vbulles');
if(!rm){
  for(let i=0;i<7;i++){
    const c=document.createElementNS('http://www.w3.org/2000/svg','circle');
    c.setAttribute('r',1.6+Math.random()*2.6);
    c.setAttribute('cx',62+Math.random()*76);
    c.setAttribute('fill','rgba(255,255,255,.5)');
    vb.appendChild(c);
    const dur=2.6+Math.random()*2.4;
    c.animate([{transform:'translateY(0px)',opacity:0},{opacity:.7,offset:.15},{transform:'translateY(-185px)',opacity:0}],{duration:dur*1000,iterations:Infinity,delay:Math.random()*2600});
    c.setAttribute('cy',262);
  }
}

/* compteur anim&eacute; */
const cible=100000000,el=document.getElementById('compteur');
const ioC=new IntersectionObserver(es=>{
  if(es[0].isIntersecting){
    ioC.disconnect();
    if(rm){el.textContent='100,000,000';return}
    const t0=performance.now(),dur=2200;
    function tick(t){
      const p=Math.min(1,(t-t0)/dur),e=1-Math.pow(1-p,3);
      el.textContent=Math.round(cible*e).toLocaleString('en-GB');
      if(p<1)requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }
},{threshold:.4});
ioC.observe(el);

</script>
